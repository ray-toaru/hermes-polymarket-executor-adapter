# Hermes executor adapter environment example.
# Copy outside source control before use. Do not commit real tokens.

# Executor API base URL. Required to avoid silently targeting a local default.
PM_EXEC_SERVICE_URL=http://localhost:8080

# Bearer token for service/query executor routes.
# Required for all native Hermes service tools.
# Must match the target engine API's PMX_API_SERVICE_TOKEN value.
PM_EXEC_SERVICE_TOKEN=REPLACE_WITH_SERVICE_BEARER_TOKEN

# Bearer token for admin executor routes.
# Required only for admin toolset operations and must be distinct from service token.
# Must match the target engine API's PMX_API_ADMIN_TOKEN value.
PM_EXEC_ADMIN_TOKEN=REPLACE_WITH_DISTINCT_ADMIN_BEARER_TOKEN
